# Required: Your Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Required: Comma-separated list of Telegram chat IDs to send videos to
TELEGRAM_CHAT_IDS=-1001234567890,123456789

# Optional: Restrict API access to a specific subnet (CIDR notation)
# Leave empty to allow all IPs (not recommended for public exposure)
ALLOWED_SUBNET=192.168.1.0/24

# Optional: Custom ffmpeg binary path (default: ffmpeg)
FFMPEG_PATH=ffmpeg

# Optional: Port to listen on (default: 8080)
PORT=8080
